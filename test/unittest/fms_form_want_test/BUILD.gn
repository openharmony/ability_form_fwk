import("//build/test.gni")
import("//foundation/ability/form_fwk/form_fwk.gni")

module_output_path = "form_fwk/form_fwk/form_mgr_service"

ohos_unittest("FmsFormWantTest") {
  module_out_path = module_output_path
  
  sources = [
    "${form_fwk_path}/test/unittest/fms_form_want_test/fms_form_want_test.cpp",
  ]
  
  include_dirs = [
    "${form_fwk_path}/interfaces/inner_api/include",
    "${form_fwk_path}/services/include",
    "${form_fwk_path}/test/mock/include",
  ]
  
  configs = []
  cflags = []
  
  deps = [
    "${form_fwk_path}:libfms",
    "${form_fwk_path}:form_manager",
  ]
  
  external_deps = [
    "ability_base:want",
    "ability_base:base",
    "ability_runtime:ability_connect_callback_stub",
    "c_utils:utils",
    "hilog:libhilog",
    "ipc:ipc_core",
  ]
}

group("unittest") {
  testonly = true
  deps = [
    ":FmsFormWantTest",
  ]
}