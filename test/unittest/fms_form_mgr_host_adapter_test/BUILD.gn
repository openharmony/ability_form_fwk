import("//build/test.gni")
import("//foundation/ability/form_fwk/form_fwk.gni")

module_output_path = "form_fwk/form_fwk/form_mgr_service"

ohos_unittest("FmsFormMgrHostAdapterTest") {
  module_out_path = module_output_path

  sources = [
    "${form_fwk_path}/test/unittest/fms_form_mgr_host_adapter_test/fms_form_mgr_host_adapter_test.cpp",
    "${form_fwk_path}/test/unittest/fms_form_data_mgr_test/mock_form_db_cache.cpp",
    "${form_fwk_path}/services/src/form_host/form_mgr_host_adapter.cpp",
    "${form_fwk_path}/interfaces/inner_api/src/form_provider_info.cpp",
  ]

  include_dirs = [
    "${form_fwk_path}/test/unittest/fms_form_data_mgr_test",
    "${form_fwk_path}/interfaces/inner_api/include",
    "${form_fwk_path}/services/include",
  ]

  configs = []
  cflags = []
  if (target_cpu == "arm") {
    cflags += [ "-DBINDER_IPC_32BIT" ]
  }
  deps = [
    "${form_fwk_path}:fms_target",
    "${form_fwk_path}:fmskit_native",
    "${form_fwk_path}:libfms",
    "${form_fwk_path}:form_utils",
    "${form_fwk_path}:form_common_info",
    "${form_fwk_path}:form_render_info",
  ]

  external_deps = [
    "ability_base:base",
    "ability_base:want",
    "ability_runtime:app_manager",
    "access_token:libaccesstoken_sdk",
    "bundle_framework:appexecfwk_base",
    "bundle_framework:appexecfwk_core",
    "c_utils:utils",
    "common_event_service:cesfwk_innerkits",
    "eventhandler:libeventhandler",
    "ffrt:libffrt",
    "googletest:gtest_main",
    "googletest:gmock_main",
    "hilog:libhilog",
    "ipc:ipc_core",
    "kv_store:distributeddata_inner",
    "safwk:system_ability_fwk",
    "samgr:samgr_proxy",
  ]
}
 
###############################################################################
group("unittest") {
  testonly = true
 
  deps = [
    ":FmsFormMgrHostAdapterTest",
  ]
}
###############################################################################