import("//build/test.gni")
import("//foundation/ability/form_fwk/form_fwk.gni")

module_output_path = "form_fwk/form_fwk/form_common_adapter"

ohos_unittest("FmsFormCommonAdapterTest") {
  module_out_path = module_output_path

  sources = [
    "${form_fwk_path}/services/src/form_mgr/form_common_adapter.cpp",
    "${form_fwk_path}/interfaces/inner_api/src/form_provider_data.cpp",
    "${form_fwk_path}/interfaces/inner_api/src/form_provider_info.cpp",
    "${form_fwk_path}/interfaces/inner_api/src/form_ashmem.cpp",
    "${form_fwk_path}/test/mock/src/mock_form_data_mgr.cpp",
    "${form_fwk_path}/test/mock/src/mock_form_info_mgr.cpp",
    "${form_fwk_path}/test/mock/src/mock_form_bms_helper.cpp",
    "${form_fwk_path}/test/mock/src/mock_form_timer_mgr.cpp",
    "${form_fwk_path}/test/mock/src/mock_form_db_cache.cpp",
    "${form_fwk_path}/test/mock/src/mock_form_bundle_forbid_mgr.cpp",
    "${form_fwk_path}/test/mock/src/mock_form_bundle_lock_mgr.cpp",
    "${form_fwk_path}/test/mock/src/mock_form_exempt_lock_mgr.cpp",
    "${form_fwk_path}/test/mock/src/mock_form_distributed_mgr.cpp",
    "${form_fwk_path}/test/mock/src/mock_param_control.cpp",
    "${form_fwk_path}/test/mock/src/mock_ipc_skeleton.cpp",
    "fms_form_common_adapter_test.cpp",
  ]

  include_dirs = [
    "${form_fwk_path}/services/include",
    "${form_fwk_path}/services/include/form_mgr",
    "${form_fwk_path}/services/include/common/util",
    "${form_fwk_path}/services/include/data_center",
    "${form_fwk_path}/services/include/data_center/form_info",
    "${form_fwk_path}/services/include/data_center/form_record",
    "${form_fwk_path}/services/include/feature/bundle_lock",
    "${form_fwk_path}/services/include/feature/bundle_forbidden",
    "${form_fwk_path}/services/include/feature/bundle_distributed",
    "${form_fwk_path}/services/include/feature/param_update",
    "${form_fwk_path}/services/include/bms_mgr",
    "${form_fwk_path}/services/include/common/timer_mgr",
    "${form_fwk_path}/services/include/data_center/database",
    "${form_fwk_path}/interfaces/inner_api/include",
    "${form_fwk_path}/test/mock/include",
  ]

  configs = [ "${form_fwk_path}/test:formmgr_test_config" ]
  cflags = []

  if (target_cpu == "arm") {
    cflags += [ "-DBINDER_IPC_32BIT" ]
  }

  deps = [
    "${form_fwk_path}:fms_target",
    "${form_fwk_path}:fmskit_native",
    "${form_fwk_path}:form_manager",
  ]

  external_deps = [
    "ability_base:want",
    "ability_runtime:app_manager",
    "bundle_framework:appexecfwk_base",
    "bundle_framework:appexecfwk_core",
    "c_utils:utils",
    "ffrt:libffrt",
    "googletest:gmock_main",
    "hilog:libhilog",
    "ipc:ipc_core",
    "libxml2:libxml2",
    "safwk:system_ability_fwk",
    "samgr:samgr_proxy",
  ]
}

###############################################################################
group("unittest") {
  testonly = true

  deps = [ ":FmsFormCommonAdapterTest" ]
}
###############################################################################
