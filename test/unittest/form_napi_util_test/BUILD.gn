import("//build/test.gni")
import("//foundation/ability/form_fwk/form_fwk.gni")

config("form_napi_util_test_config") {
  include_dirs = [ "${form_fwk_path}/frameworks/js/napi/formUtil" ]
}

# ohos_unittest is a template that will add gtest as deps.
ohos_unittest("FmsFormNapiUtilTest") {
  module_out_path = "form_fwk/form_fwk/form_napi_util"

  configs = [ ":form_napi_util_test_config" ]

  sources = [ "form_napi_util_test.cpp" ]

  deps = [
    "${form_fwk_napi_path}:formutil_napi",
    "${form_fwk_path}:fmskit_native",
  ]

  external_deps = [
    "ability_base:want",
    "ability_runtime:abilitykit_native",
    "ability_runtime:app_manager",
    "ability_runtime:napi_common",
    "bundle_framework:appexecfwk_base",
    "bundle_framework:appexecfwk_core",
    "c_utils:utils",
    "eventhandler:libeventhandler",
    "hilog:libhilog",
    "ipc:ipc_core",
    "napi:ace_napi",
    "samgr:samgr_proxy",
    "googletest:gmock_main",
  ]
}

group("unittest") {
  testonly = true
  deps = [ ":FmsFormNapiUtilTest" ]
}
