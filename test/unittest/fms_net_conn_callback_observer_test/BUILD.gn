import("//build/test.gni")
import("//foundation/ability/form_fwk/form_fwk.gni")

module_output_path = "form_fwk/form_fwk/form_mgr_service"

ohos_unittest("FmsNetConnCallbackObserverTest") {
  module_out_path = module_output_path

  sources = [
    "${form_fwk_path}/services/src/common/util/form_util.cpp",
    "${form_fwk_path}/services/src/form_observer/net_conn_callback_observer.cpp",
    "${form_fwk_path}/test/unittest/fms_net_conn_callback_observer_test/fms_net_conn_callback_observer_test.cpp",
  ]

  include_dirs = [
    "${form_fwk_path}/interfaces/inner_api/include",
    "${form_fwk_path}/services/include",
    "${form_fwk_path}/services/common/include",
  ]

  configs = []
  cflags = []
  if (target_cpu == "arm") {
    cflags += [ "-DBINDER_IPC_32BIT" ]
  }
  deps = [
    "${form_fwk_path}:fms_target",
    "${form_fwk_path}:libfms",
    "${form_fwk_path}:form_render_info",
    "${form_fwk_path}:form_utils",
    "${form_fwk_path}:form_common_info",
  ]

  external_deps = [
    "ability_base:want",
    "ability_runtime:ability_deps_wrapper",
    "ability_runtime:app_manager",
    "access_token:libaccesstoken_sdk",
    "ability_runtime:wantagent_innerkits",
    "bundle_framework:appexecfwk_base",
    "bundle_framework:appexecfwk_core",
    "c_utils:utils",
    "data_share:datashare_common",
    "data_share:datashare_consumer",
    "data_share:datashare_provider",
    "ffrt:libffrt",
    "googletest:gmock_main",
    "hicollie:libhicollie",
    "hilog:libhilog",
    "hisysevent:libhisysevent",
    "huks:libhukssdk",
    "ipc:ipc_core",
    "libxml2:libxml2",
    "netmanager_base:net_conn_manager_if",
    "os_account:os_account_innerkits",
    "safwk:system_ability_fwk",
    "samgr:samgr_proxy",
    "ipc:ipc_core",
  ]
}

group("unittest") {
  testonly = true

  deps = [ ":FmsNetConnCallbackObserverTest" ]
}
